{
  "name": "multi-resolution-timeseries-parquet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Serve years of high-frequency time-series to a browser chart — no backend, no database. Multi-resolution Parquet tiers + HTTP range requests.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "generate": "tsx scripts/generate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hyparquet": "^1.26.2",
    "hyparquet-writer": "^0.16.1",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
